# --- Paths (persistent data on the cluster host) ---
TPW_CONTAINER_PREFIX=tpw_target2
TPW_DB_DIR=/data/targetpathogen/db
TPW_DATA_DIR=/data/targetpathogen/data
TPW_FASTTARGET_DB_DIR=/data/targetpathogen/fasttarget_db
TPW_FASTTARGET_RUNTIME_DIR=/data/targetpathogen/fasttarget/organism
TPW_FASTTARGET_LOG_DIR=/data/targetpathogen/fasttarget/logs
TPW_P2RANK_DIR=/data/targetpathogen/opt/p2rank
TPW_EDGE_NETWORK=internal-nodo0-web
TPW_ROUTER_NAME=tpw_target2_nodo0
TPW_DB_PORT_BIND=127.0.0.1:15433
TPW_WEB_PORT_BIND=127.0.0.1:18085
TPW_JBROWSE_PORT_BIND=127.0.0.1:13001
QUEUE_POLL_INTERVAL=10
TPW_USE_DIRECT_PIPELINE=1
# Long-running stage 16 (ColabFold on CPU) easily exceeds 6h on cluster.
# Keep this high unless you explicitly want uploads to be killed earlier.
TPW_PIPELINE_TIMEOUT_SEC=86400

# --- Security — MUST change these ---
TPW_DB_PASSWORD=CHANGE_ME
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_DATABASE_PASSWORD=CHANGE_ME
DJANGO_DEBUG=False

# --- Hosts — add your cluster domain ---
TPW_DOMAIN=target2.infra.cluster.qb.fcen.uba.ar
DJANGO_ALLOWED_HOSTS=localhost,target2.infra.cluster.qb.fcen.uba.ar
DJANGO_ROOT=/app/staticfiles
JBROWSE_BASE_URL=http://localhost:13001/
SEQS_DATA_DIR=/app/targetpathogenweb/data
REDIS_URL=
SENTRY_DSN=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# --- SSH (for remote pipeline execution) ---
SSH_HOSTNAME=CHANGE_ME
SSH_USERNAME=CHANGE_ME
SSH_KEY_FILENAME=
SSH_WORKDIR=CHANGE_ME
SSH_CORES=16

# --- Heavy pipeline stages: keep local execution disabled on nodo0 ---
TPW_FORBID_LOCAL_HEAVY=1

# Generic SLURM hooks for heavy stages that do not have a dedicated wrapper.
# The command runs on the remote SLURM side. It receives formatted values:
# {genome}, {working_dir}, {folder_path}. Configure only after confirming the
# remote job can access or stage the needed input/output files.
TPW_FASTTARGET_USE_REMOTE=0
TPW_FASTTARGET_REMOTE_COMMAND=
TPW_FASTTARGET_SLURM_PARTITION=cpu
TPW_FASTTARGET_SLURM_TIME=48:00:00
TPW_FASTTARGET_SLURM_MEM=64G
TPW_FASTTARGET_SLURM_CPUS=16

TPW_STRUCTURES_USE_REMOTE=0
TPW_STRUCTURES_REMOTE_SETUP=
TPW_STRUCTURES_FPOCKET_BIN=fpocket
TPW_STRUCTURES_P2RANK_BIN=prank
TPW_STRUCTURES_SLURM_PARTITION=cpu
TPW_STRUCTURES_SLURM_TIME=48:00:00
TPW_STRUCTURES_SLURM_MEM=32G
TPW_STRUCTURES_SLURM_CPUS=8

TPW_BINDERS_USE_REMOTE=0
TPW_BINDERS_REMOTE_COMMAND=
TPW_BINDERS_SLURM_PARTITION=cpu
TPW_BINDERS_SLURM_TIME=24:00:00
TPW_BINDERS_SLURM_MEM=16G
TPW_BINDERS_SLURM_CPUS=4

# SSH keys directory on the cluster host (mounted read-only into web/queue containers)
# Default: dockeradmin's home dir — adjust if different
TPW_SSH_DIR=/home/dockeradmin/.ssh
