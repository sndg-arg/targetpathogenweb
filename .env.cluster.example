# --- Paths (persistent data on the cluster host) ---
TPW_CONTAINER_PREFIX=tpw_target2
TPW_DB_DIR=/data/targetpathogen/db
TPW_DATA_DIR=/data/targetpathogen/data
TPW_FASTTARGET_DB_DIR=/data/targetpathogen/fasttarget/databases
TPW_FASTTARGET_RUNTIME_DIR=/data/targetpathogen/fasttarget/organism
TPW_FASTTARGET_LOG_DIR=/data/targetpathogen/fasttarget/logs
TPW_EDGE_NETWORK=internal-nodo0-web
TPW_DB_PORT_BIND=127.0.0.1:15432
TPW_WEB_PORT_BIND=127.0.0.1:18085
TPW_JBROWSE_PORT_BIND=13000
QUEUE_POLL_INTERVAL=10

# --- Security — MUST change these ---
TPW_DB_PASSWORD=CHANGE_ME
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_DATABASE_PASSWORD=CHANGE_ME
DJANGO_DEBUG=False

# --- Hosts — add your cluster domain ---
DJANGO_ALLOWED_HOSTS=localhost,target2.sbg.qb.fcen.uba.ar
DJANGO_ROOT=/app/staticfiles
JBROWSE_BASE_URL=http://localhost:13000/
SEQS_DATA_DIR=/app/targetpathogenweb/data/seqs
REDIS_URL=
SENTRY_DSN=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# --- SSH (for remote pipeline execution) ---
SSH_HOSTNAME=CHANGE_ME
SSH_USERNAME=CHANGE_ME
SSH_WORKDIR=CHANGE_ME
SSH_CORES=16
