services:
  db:
    volumes:
      - ./dbs/db:/var/lib/postgresql/data
  web:
    deploy:
      resources:
        limits:
          memory: 4g
          cpus: '2.0'
    volumes:
      - ./:/app/targetpathogenweb
      - ./data:/app/targetpathogenweb/data
      # Point to your local fasttarget checkout:
      - ./fasttarget_mac:/app/fasttarget
      # Mac SSH agent socket workaround (Docker Desktop):
      - ./dummy_ssh:/ssh-agent
      - /run/host-services/ssh-auth.sock:/run/host-services/ssh-auth.sock
    environment:
      - SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock
      - PYTHONPATH=/app/sndgjobs:/app/sndgbiodb:/app/targetpathogen:/app/sndg-bio:/app/target
